# Copy this file to .env.local and fill in your values.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Faculty passwords ─────────────────────────────────────────────────────────
# One env var per faculty. Key format: FACULTY_<CODE>_PASSWORD
# Change all of these before going live — do NOT use the default values.
FACULTY_COMMARTS_PASSWORD=
FACULTY_BUSINESS_PASSWORD=
FACULTY_ACCOUNT_PASSWORD=
FACULTY_LAW_PASSWORD=
FACULTY_HUSO_PASSWORD=
FACULTY_ECON_PASSWORD=
FACULTY_ENG_PASSWORD=
FACULTY_SCI_PASSWORD=
FACULTY_IT_PASSWORD=
FACULTY_ARCH_PASSWORD=
FACULTY_FINEART_PASSWORD=
FACULTY_DMCA_PASSWORD=
FACULTY_BUSEM_PASSWORD=

# ── Approver password ─────────────────────────────────────────────────────────
APPROVER_PASSWORD=
